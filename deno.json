{
  "tasks": {
    "refresh": "deno run --unstable-http --allow-net --allow-read --allow-write refresh.ts",
    "daily": "deno run --unstable-http --allow-net daily.ts",
    "pick": "deno run --unstable-http --allow-net picker.ts",
    "analyze": "deno run --unstable-http --allow-net analyzeStock.ts",
    "bandar": "deno run --unstable-http --allow-net bandarHistory.ts",
    "bandar-top": "deno run --unstable-http --allow-net bandarToday.ts",
    "orderbook": "deno run --unstable-net --allow-net orderbook.ts",
    "trap": "deno run --unstable-http --allow-net trapCheck.ts"
  },
  "compilerOptions": {
    "strict": true
  },
  "nodeModulesDir": "auto"
}
